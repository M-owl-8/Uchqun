# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=uchqun
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
# Set to true in production to enforce SSL certificate verification
# DB_SSL=true

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be 32+ random characters, different from JWT_REFRESH_SECRET
JWT_SECRET=change_me_at_least_32_chars_long_secret
JWT_REFRESH_SECRET=change_me_different_32_chars_long_secret
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (added on top of hardcoded defaults)
FRONTEND_URL=http://localhost:5173,http://localhost:5174,http://localhost:5175
# Set to 'true' to enforce strict CORS even in development
CORS_STRICT=false

# ─── AI (OpenAI / OpenRouter) ─────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# ─── File Storage (Appwrite) ──────────────────────────────────────────────────
APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_BUCKET_ID=

# ─── Notifications ────────────────────────────────────────────────────────────
# Telegram bot for sending admin approval credentials
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Email (Nodemailer)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# ─── Error Tracking (Sentry) ──────────────────────────────────────────────────
SENTRY_DSN=

# ─── Rate Limiting (optional overrides) ───────────────────────────────────────
# AUTH_LIMIT_MAX=50
# AUTH_LIMIT_WINDOW_MS=900000
# UPLOAD_LIMIT_MAX=50
# UPLOAD_LIMIT_WINDOW_MS=900000

# ─── Migrations / Sync ────────────────────────────────────────────────────────
# Set to 'true' to run Sequelize migrations on server start
RUN_MIGRATIONS=false
# DANGER: drops and recreates all tables — development only
FORCE_SYNC=false

# ─── Public URL ───────────────────────────────────────────────────────────────
# Used for generating absolute URLs to uploaded files
API_URL=http://localhost:5000
