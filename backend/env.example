# Server Configuration
PORT=5000
NODE_ENV=development

# PostgreSQL Configuration
DB_NAME=uchqun
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS Configuration
# Can be a single URL or multiple URLs separated by commas
# Allowed frontend URLs for CORS
FRONTEND_URL=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,https://uchqun-platform.vercel.app

# Database Sync (set to true to force recreate tables - use with caution!)
FORCE_SYNC=false

# Migration Secret (required for POST /api/migrations/run)
MIGRATION_SECRET=your-migration-secret-change-this

# OpenAI/OpenRouter Configuration (Optional - for AI chat assistant)
# Option 1: Use OpenAI directly
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-3.5-turbo

# Option 2: Use OpenRouter (supports multiple AI models)
# Get your API key from: https://openrouter.ai/keys
OPENAI_API_KEY=your-openrouter-api-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Free models (no credits needed): qwen/qwen-2.5-7b-instruct:free, deepseek/deepseek-r1-0528:free, meta-llama/llama-3.2-3b-instruct:free
# Paid models: gpt-3.5-turbo, gpt-4, claude-3-opus, claude-3-son        net, etc.
# If not set, will automatically try free models if credits are insufficient
OPENAI_MODEL=qwen/qwen-2.5-7b-instruct:free

# API base URL (used for generating file URLs when using local storage)
# In production set to your backend URL, e.g. https://uchqun-production-up.railway.app
# In development you can leave default (http://localhost:5000)
# API_URL=https://uchqun-production-up.railway.app

# Appwrite Storage Configuration
# Required for storing media files persistently in Appwrite
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_API_KEY=your-appwrite-api-key
APPWRITE_BUCKET_ID=your-appwrite-bucket-id

# Telegram Bot Configuration
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Channel or Group ID where bot will send messages (with @ prefix for public channels, or numeric ID for private)
# Example for public channel: @your_channel_name
# Example for private channel/group: -1001234567890
TELEGRAM_CHANNEL_ID=@your_channel_name_or_chat_id

# Payment Provider Configuration
# Payme (https://developer.help.paycom.uz/)
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_MERCHANT_KEY=your-payme-merchant-key
PAYME_TEST_MODE=true

# Click (https://docs.click.uz/)
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SERVICE_ID=your-click-service-id
CLICK_SECRET_KEY=your-click-secret-key
CLICK_MERCHANT_USER_ID=your-click-merchant-user-id


