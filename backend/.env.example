# ──────────────────────────────────────────────────────────────────────────────
# Uchqun Backend — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=5000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Railway sets DATABASE_URL automatically. For local Docker use DB_* vars.
DATABASE_URL=postgresql://user:pass@localhost:5432/uchqun
# DATABASE_PUBLIC_URL=postgresql://user:pass@<railway-host>:5432/uchqun  # Railway external URL
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=uchqun
# DB_USER=postgres
# DB_PASSWORD=yourpassword

# ── Authentication ─────────────────────────────────────────────────────────────
# Use at least 64 random bytes; JWT_SECRET and JWT_REFRESH_SECRET must differ.
JWT_SECRET=change-me-at-least-64-random-chars
JWT_REFRESH_SECRET=change-me-different-from-jwt-secret

# Access tokens are hardcoded to 15m; refresh tokens to 7d in authController.js.
# Override here only if you need different defaults.
# JWT_EXPIRE=15m
# JWT_REFRESH_EXPIRE=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of additional allowed origins (merged with built-in list).
FRONTEND_URL=https://uchqun-admin.netlify.app,https://uchqun-teacher.netlify.app,https://uchqun-reception.netlify.app,https://uchqun-government.netlify.app
# Set to 'true' to reject any origin not in the explicit allowlist (production).
CORS_STRICT=false

# ── Migrations ────────────────────────────────────────────────────────────────
# HMAC-SHA256 secret for POST /api/migrations/run.
MIGRATION_SECRET=change-me-long-random-secret

# Set to 'true' to run migrations automatically on server startup.
RUN_MIGRATIONS=false

# ── Email (SMTP/Nodemailer) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false             # true for port 465 (TLS), false for STARTTLS
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
EMAIL_FROM="Uchqun Platform <noreply@uchqun.uz>"

# ── Telegram notifications ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=           # BotFather token; leave blank to disable
TELEGRAM_CHANNEL_ID=          # e.g. -1001234567890

# ── AI / OpenRouter ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-or-v1-...   # OpenRouter key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=google/gemma-3-27b-it:free

# ── Appwrite (document & avatar storage) ─────────────────────────────────────
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=REPLACE_ME
APPWRITE_API_KEY=REPLACE_ME
APPWRITE_BUCKET_ID=REPLACE_ME

# ── File uploads (local fallback, dev only) ───────────────────────────────────
LOCAL_UPLOADS_DIR=./uploads
# LOCAL_STORAGE_FALLBACK=false  # dev only; automatically disabled in production
API_URL=http://localhost:5000  # used to build absolute file URLs

# ── Redis ─────────────────────────────────────────────────────────────────────────────
# Optional — distributed login lockout and JTI revocation.
# Falls back to in-memory when unset (single-instance only).
# Set REDIS_URL in Railway for multi-instance deployments.
# REDIS_URL=redis://default:REPLACE_ME@<redis-host>:6379

# ── Rate limiting ─────────────────────────────────────────────────────────────
# AUTH_LIMIT_WINDOW_MS=900000  # 15 min window for login attempts
# AUTH_LIMIT_MAX=20
# UPLOAD_LIMIT_WINDOW_MS=60000
# UPLOAD_LIMIT_MAX=10

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                 # error | warn | info | http | verbose | debug

# ── Error tracking (optional) ─────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ── Seed / test accounts (development only — NEVER set in production) ─────────
ADMIN_EMAIL=admin@school.test
ADMIN_PASSWORD=Admin123!
GOVERNMENT_EMAIL=gov@school.test
GOVERNMENT_PASSWORD=Gov123!
TEACHER_EMAIL=teacher@school.test
TEACHER_PASSWORD=Teacher123!
PARENT_EMAIL=parent@school.test
PARENT_PASSWORD=Parent123!
RECEPTION_EMAIL=reception@school.test
RECEPTION_PASSWORD=Reception123!

# ── Dangerous flags ────────────────────────────────────────────────────────────
# FORCE_SYNC=false  # DROPS ALL TABLES — development only, NEVER in production
# DEBUG_AUTH=false  # logs full JWT payloads — leaks PII
