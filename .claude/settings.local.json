{
  "permissions": {
    "allow": [
      "Read", "Write", "Edit", "Glob", "Grep",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(git reset:*)",
      "Bash(git pull:*)",
      "Bash(git push origin:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(dir:*)",
      "Bash(type:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(curl:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(eslint:*)",
      "Bash(jest:*)",
      "Bash(vitest:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin main --force:*)",
      "Bash(git push origin main -f:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(rm -rf %USERPROFILE%:*)",
      "Bash(rm -rf C:*)",
      "Bash(rm -rf D:*)",
      "Bash(rm -rf ..:*)",
      "Bash(npm publish:*)",
      "Bash(npm run deploy:*)",
      "Bash(railway up:*)",
      "Bash(railway deploy:*)",
      "Bash(netlify deploy --prod:*)",
      "Bash(vercel --prod:*)",
      "Bash(psql:* DROP DATABASE)",
      "Bash(dropdb:*)",
      "Bash(*FORCE_SYNC=true*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)"
    ]
  }
}
