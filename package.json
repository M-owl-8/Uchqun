{
  "name": "uchqun-platform",
  "version": "1.0.0",
  "description": "Government-owned web platform for special education school management in Uzbekistan",
  "private": true,
  "scripts": {
    "migrate": "cd backend && npm run migrate",
    "seed": "cd backend && npm run seed",
    "prepare": "husky"
  },
  "lint-staged": {
    "backend/**/*.js": [
      "npx eslint --fix --config backend/.eslintrc.cjs"
    ],
    "admin/src/**/*.{js,jsx}": [
      "npx eslint --fix --config admin/.eslintrc.cjs"
    ],
    "teacher/src/**/*.{js,jsx}": [
      "npx eslint --fix --config teacher/.eslintrc.cjs"
    ],
    "reception/src/**/*.{js,jsx}": [
      "npx eslint --fix --config reception/.eslintrc.cjs"
    ],
    "government/src/**/*.{js,jsx}": [
      "npx eslint --fix --config government/.eslintrc.cjs"
    ]
  },
  "keywords": [
    "education",
    "schools",
    "multi-tenant",
    "uzbekistan",
    "government",
    "special-education"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "dependencies": {
    "axios": "^1.16.0"
  }
}
